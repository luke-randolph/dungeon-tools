{
  "name": "@dungeon-tools/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "fetch-spells": "tsx scripts/fetchSpells.ts",
    "fetch-srd": "tsx scripts/fetchSRD.ts",
    "build-feature-data": "node scripts/build-feature-data.mjs",
    "tag-feature-groups": "tsx scripts/tagFeatureGroups.ts",
    "build-features": "npm run build-feature-data && npm run tag-feature-groups",
    "refresh-srd-data": "npm run fetch-spells && npm run fetch-srd && npm run build-features"
  },
  "dependencies": {
    "@dungeon-tools/shared": "workspace:*",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.3.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/material-top-tabs": "^7.2.0",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-drawer-layout": "^4.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^4.0.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  }
}
